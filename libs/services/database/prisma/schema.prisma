generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


//for bookings service
enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Booking {
  id String @id @default(uuid())
  userClientId String
  userProviderId String
  startTime DateTime
  endTime DateTime
  amount Decimal
  currency String
  paymentMethod String
  status BookingStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userClientId, userProviderId, startTime, endTime])
}



model Payment {
  id String @id @default(uuid())
}